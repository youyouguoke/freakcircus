\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"• Ignore Pierrot's direct questions in Scene 14\\\"}],[\\\"$\\\",\\\"li\\\",null,{\\\"children\\\":\\\"• The screen will remain black for 3-4 minutes before credits roll\\\"}]]}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-on-surface-variant text-sm\\\",\\\"children\\\":\\\"Players report that Pierrot references previous unselected choices during the silent route, suggesting the game maintains memory of player behavior across saves. This mechanic is not documented in the official guide and was discovered through community testing in 2025.\\\"}]]}]\\n\"])</script><script>self.__next_f.push([1,\"7:[\\\"$\\\",\\\"section\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\\\",\\\"children\\\":\\\"Hidden Dialogue Triggers\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-on-surface-variant text-sm mb-4\\\",\\\"children\\\":\\\"Pierrot's route contains multiple hidden dialogue triggers that require specific conditions:\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"bg-surface-container border border-outline/20 p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-bold text-foreground mb-2\\\",\\\"children\\\":\\\"Garden Scene Hidden Choice\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-on-surface-variant text-sm\\\",\\\"children\\\":\\\"After failing Pierrot's route once, the garden scene in Act III gains a third option: \\\\\\\"Say Nothing.\\\\\\\" This option does not appear in the script files and was discovered through data mining in build 1.03.\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"bg-surface-container border border-outline/20 p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-bold text-foreground mb-2\\\",\\\"children\\\":\\\"Scene 14 Replay Dialogue\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-on-surface-variant text-sm\\\",\\\"children\\\":\\\"On the 4th playthrough, Pierrot begins referencing events from previous routes. The line \\\\\\\"You chose differently last time\\\\\\\" appears regardless of whether the player actually selected that choice.\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"bg-surface-container border border-outline/20 p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-bold text-foreground mb-2\\\",\\\"children\\\":\\\"Post-Credits Scene\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-on-surface-variant text-sm\\\",\\\"children\\\":\\\"After completing the Silent Route, wait through the full credits. A 30-second scene plays showing Pierrot alone in the garden, speaking to an empty chair. The dialogue references the player's real-world playtime.\\\"}]]}]]}]]}]\\n\"])</script><script>self.__next_f.push([1,\"8:[\\\"$\\\",\\\"section\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\\\",\\\"children\\\":\\\"Pierrot Route Endings\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"space-y-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"bg-surface-container border border-outline/20 p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-bold text-foreground mb-2\\\",\\\"children\\\":\\\"Smile For Me (Main Ending)\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-on-surface-variant text-sm\\\",\\\"children\\\":\\\"Accept Pierrot's offer in the garden scene. Standard ending with bittersweet conclusion. Unlocked by default on first playthrough.\\\"}]]}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"bg-surface-container border border-outline/20 p-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"h3\\\",null,{\\\"className\\\":\\\"font-bold text-foreground mb-2\\\",\\\"child