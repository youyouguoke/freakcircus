2.png\",\"image\"]\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"main\",null,{\"className\":\"min-h-screen\",\"children\":[[\"$\",\"$L2\",null,{}],[\"$\",\"article\",null,{\"className\":\"bg-surface py-16 px-4 md:px-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-4xl mx-auto\",\"children\":[[\"$\",\"div\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant mb-4\",\"children\":\"ROUTE_GUIDE // PIERROT\"}],[\"$\",\"h1\",null,{\"className\":\"font-[Creepster] text-4xl md:text-6xl text-primary mb-4\",\"children\":\"Pierrot Route Guide\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-lg mb-8\",\"children\":\"Complete walkthrough for Pierrot's main route and silent route, including hidden dialogue triggers and unlock conditions.\"}],[\"$\",\"div\",null,{\"className\":\"space-y-12\",\"children\":[[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Pierrot Main Route Overview\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"Pierrot's main route is the most commonly recommended starting point for new players. It introduces core mechanics including the dialogue choice system, the comfort/confess dynamic, and the first instance of replay-aware dialogue. The route takes approximately 4-6 hours for a first playthrough and contains 12 major scenes with branching decisions.\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The main route ending, \\\"Smile For Me,\\\" triggers when players accept Pierrot's offer during the garden scene in Act III. However, community testing has revealed that this ending is not the full picture — Pierrot's route contains hidden content that only appears after specific refusal conditions and cross-route dependencies.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"How to Unlock the Silent Route\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The Silent Route is Pierrot's secret ending path and requires refusing every major dialogue interaction during the final act. This is not a passive ending — silence becomes a deliberate choice that breaks the game's narrative contract. The unlock conditions are:\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-on-surface-variant text-sm mb-4\",\"children\":[[\"$\",\"li\",null,{\"children\":\"• Refuse all dialogue options in Scenes 10, 11, and 12\"}],[\"$\",\"li\",null,{\"children\":\"• Do not select Comfort or Confess in the garden scene\"}],[\"$\",\"li\",null,{\"children\":\"• Ignore Pierrot's direct questions in Scene 14\"}],[\"$\",\"li\",null,{\"children\":\"• The screen will remain black for 3-4 minutes before credits roll\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Players report that Pierrot references previous unselected choices during the silent route, suggesting the game maintains memory of player behavior across saves. This mechanic is not documented in the official guide and was discovered through community testing in 2025.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Hidden Dialogue Triggers\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"Pierrot's route contains multiple hidden dialogue triggers that require specific conditions:\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Garden Scene Hidden Choice\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"After failing Pierrot's route once, the garden scene in Act III gains a third option: \\\"Say Nothing.\\\" This option does not appear in the script files and was discovered through data mining in build 1.03.\"}]]}],\"$L3\",\"$L4\"]}]]}],\"$L5\",\"$L6\"]}]]}]}],\"$L7\",\"$L8\"]}],[\"$L9\"],\"$La\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"IUN3TAefIj9tb0lzb6JCd\"}\n3:[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Scene 14 Replay Dialogue\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"On the 4th playthrough, Pierrot begins referencing events from previous routes. The line \\\"You chose differently last time\\\" appears regardless of whether the player actually selected that choice.\"}]]}]\n4:[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Post-Credits Scene\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"After completing the Silent Route, wait through the full credits. A 30-second scene plays showing Pierrot alone in the garden, speaking to an empty chair. The dialogue references the player's real-world playtime.\"}]]}]\n5:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Pierrot Route Endings\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Smile For Me (Main Ending)\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Accept Pierrot's offer in the garden scene. Standard ending with bittersweet conclusion. Unlocked by default on first playthrough.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Eternal Silence (Secret Ending)\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Refuse all dialogue in the final act. Screen remains black for 3-4 minutes. Pierrot references previous unselected choices. Requires cross-route awareness flag.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Null Route (Corrupted)\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Found in unused game files. No character appears. Player walks through empty corridors until soft-lock. Unlock conditions unknown.\"}]]}]]}]]}]\n6:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Related Content\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[\"$\",\"a\",null,{\"href\":\"/characters/pierrot-endings\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Pierrot Endings Guide\"}],[\"$\",\"a\",null,{\"href\":\"/endings/eternal-silence\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Eternal Silence Ending\"}],[\"$\",\"a\",null,{\"href\":\"/theories/pierrot-remembers-routes\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Pierrot Loop Theory\"}],[\"$\",\"a\",null,{\"href\":\"/lore/mirror-hall\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Mirror Hall Lore\"}]]}]]}]\n7:[\"$\",\"footer\",null,{\"className\":\"bg-surface border-t border-outline/10 w-full\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-6xl mx-auto px-4 md:px-16 py-6 flex flex-col md:flex-row justify-between items-center gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4\",\"children\":[[\"$\",\"img\",null,{\"src\":\"/favicon-32x32.png\",\"alt\":\"Freak Circus Hub\",\"className\":\"w-8 h-8 rounded-sm\"}],[\"$\",\"span\",null,{\"className\":\"font-[Epilogue] text-lg font-bold text-foreground\",\"children\":\"FREAK CIRCUS HUB\"}],[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant opacity-60\",\"children\":\"© 2026\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-xs text-on-surface-variant opacity-60 text-center max-w-md\",\"children\":[\"Not affiliated with the original game or its developers. All trademarks belong to their respective owners.\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:hello@freak-circus.com\",\"className\":\"underline hover:text-primary transition-colors\",\"children\":\"Contact us for removal requests\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"$Lb\",null,{\"href\":\"/privacy-policy\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Privacy\"}],[\"$\",\"$Lb\",null,{\"href\":\"/terms-of-service\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Terms\"}],[\"$\",\"a\",null,{\"href\":\"mailto:hello@freak-circus.com\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Contact\"}]]}]]}]}]\nc:T1339,{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"WebPage\",\"@id\":\"https://freak-circus.com/#webpage\",\"url\":\"https://freak-circus.com\",\"name\":\"The Freak Circus Guide, Endings, Characters & Hidden Lore Archive\",\"description\":\"The ultimate fan archive for The Freak Circus horror visual novel. Explore character guides, all endings explained, walkthroughs, hidden routes, timeline lore, and community theories.\",\"isPartOf\":{\"@id\":\"https://freak-circus.com/#website\"},\"about\":{\"@type\":\"VideoGame\",\"name\":\"The Freak Circus\",\"genre\":[\"Horror\",\"Visual Novel\",\"Indie\"],\"applicationCategory\":\"Game\",\"operatingSystem\":\"Any\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}},{\"@type\":\"WebSite\",\"@id\":\"https://freak-circus.com/#website\",\"url\":\"https://freak-circus.com\",\"name\":\"Freak Circus Hub\",\"description\":\"A fan-maintained archive documenting characters, endings, theories, and hidden routes for The Freak Circus.\",\"publisher\":{\"@id\":\"https://freak-circus.com/#organization\"}},{\"@type\":\"Organization\",\"@id\":\"https://freak-circus.com/#organization\",\"name\":\"Freak Circus Hub\",\"url\":\"https://freak-circus.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://freak-circus.com/Logo.png\"}},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://freak-circus.com\"}]},{\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Freak Circus is an indie psychological horror visual novel that uses replay-aware mechanics to create a meta-narrative experience. Unlike traditional horror games, it builds dread through silence, repetition, and characters who appear to remember your choices across playthroughs.\"}},{\"@type\":\"Question\",\"name\":\"Is The Freak Circus free to play?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, The Freak Circus is available for free on itch.io. It runs directly in your browser without requiring download or installation. The game is rated 18+ for mature themes.\"}},{\"@type\":\"Question\",\"name\":\"How long is The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A single route playthrough takes approximately 4-6 hours. However, experiencing all content requires multiple playthroughs due to replay-aware mechanics, hidden triggers, and route dependencies. A comprehensive investigation to see all endings and hidden content can take 40+ hours.\"}},{\"@type\":\"Question\",\"name\":\"How many endings are in The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The exact number remains unknown. The community has confirmed 8 endings including standard routes (Grand Finale, Smile For Me, Doctor's Note), secret endings (Eternal Silence, Columbina's Truth), and corrupted endings (Corrupted Data, White Room).\"}},{\"@type\":\"Question\",\"name\":\"Who is Pierrot in The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pierrot is the melancholic clown and often the first route players encounter. His storyline explores themes of forgotten identity, repeated loops, and awareness that extends beyond the fourth wall. The loop theory suggests Pierrot remembers player behavior across save files.\"}},{\"@type\":\"Question\",\"name\":\"What is the Eternal Silence ending and how do you unlock it?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Eternal Silence is a secret ending on Pierrot's route that requires refusing every major dialogue interaction during the final act. The screen remains black for several minutes before credits roll. The ending suggests the only escape from the circus is to stop engaging entirely.\"}},{\"@type\":\"Question\",\"name\":\"What is the true ending of The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The community has not reached consensus on a true ending. Some theories suggest Columbina's Truth represents the most complete revelation. Others argue the Corrupted Data ending was intended as the true ending before being cut. The ambiguity appears intentional.\"}}]},{\"@type\":\"ItemList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Pierrot Character Guide\",\"url\":\"https://freak-circus.com/characters/pierrot\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Harlequin Character Guide\",\"url\":\"https://freak-circus.com/characters/harlequin\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"The Doctor Character Guide\",\"url\":\"https://freak-circus.com/characters/doctor\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Columbina Character Guide\",\"url\":\"https://freak-circus.com/characters/columbina\"},{\"@type\":\"ListItem\",\"position\":5,\"name\":\"All Endings Explained\",\"url\":\"https://freak-circus.com/endings\"},{\"@type\":\"ListItem\",\"position\":6,\"name\":\"Eternal Silence Ending Guide\",\"url\":\"https://freak-circus.com/endings/eternal-silence\"},{\"@type\":\"ListItem\",\"position\":7,\"name\":\"Walkthroughs\",\"url\":\"https://freak-circus.com/walkthroughs\"},{\"@type\":\"ListItem\",\"position\":8,\"name\":\"Lore Archive\",\"url\":\"https://freak-circus.com/lore\"}]}]}8:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$c\"}}]\n9:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0_kxktbm0~zp0.js\",\"async\":true}]\na:[\"$\",\"$Ld\",null,{\"children\":[\"$\",\"$e\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@f\"}]}]\nf:null\n","/characters/pierrot-route-guide":"1:\"$Sreact.fragment\"\n2:I[39756,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"d