nd mb-4\",\"children\":\"Community Theories\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Theory: Debug Remnant\"}],\"$L3\"]}],\"$L4\",\"$L5\"]}]]}],\"$L6\"]}]]}]}],\"$L7\"]}],[\"$L8\"],\"$L9\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"IUN3TAefIj9tb0lzb6JCd\"}\n3:[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The ending may be a debug tool left in the game files by developers. The hex dump shows standard ELF header patterns, suggesting it is not encrypted narrative content but a system crash.\"}]\n4:[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Theory: ARG Element\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The ending may be part of an alternate reality game that requires solving puzzles outside the game client. The ENDING_13_PTR reference suggests a pointer to external content.\"}]]}]\n5:[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Theory: Cut True Ending\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Some players believe Corrupted Data was the intended true ending before being cut during development. The placeholder dialogue and map file suggest a complete narrative was planned.\"}]]}]\n6:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"FAQ\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[[\"$\",\"div\",null,{\"clas