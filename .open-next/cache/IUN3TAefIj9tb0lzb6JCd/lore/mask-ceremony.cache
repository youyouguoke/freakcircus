eta\",\"1\",{\"name\":\"description\",\"content\":\"Complete guide to the Mask Ceremony in The Freak Circus. Covers mask symbolism, the ritual's significance, and how masks represent fractured identity across routes.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"author\",\"content\":\"Freak Circus Hub\"}],[\"$\",\"meta\",\"3\",{\"name\":\"keywords\",\"content\":\"Mask Ceremony,mask symbolism,The Freak Circus lore,character identity,fractured personality\"}],[\"$\",\"meta\",\"4\",{\"name\":\"creator\",\"content\":\"Freak Circus Hub\"}],[\"$\",\"meta\",\"5\",{\"name\":\"publisher\",\"content\":\"Freak Circus Hub\"}],[\"$\",\"meta\",\"6\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"7\",{\"name\":\"googlebot\",\"content\":\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"}],[\"$\",\"link\",\"8\",{\"rel\":\"canonical\",\"href\":\"https://freak-circus.com/lore/mask-ceremony\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:title\",\"content\":\"Freak Circus Hub — You Still Don't Understand the Ending\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:description\",\"content\":\"Every ending mapped. Every character connected. Every theory documented.\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:url\",\"content\":\"https://freak-circus.com\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:site_name\",\"content\":\"Freak Circus Hub\"}],[\"$\",\"meta\",\"13\",{\"property\":\"og:locale\",\"content\":\"en_US\"}],[\"$\",\"meta\",\"14\",{\"property\":\"og:image\",\"content\":\"https://freak-circus.com/OG.png\"}],[\"$\",\"meta\",\"15\",{\"property\":\"og:type\",\"content\":\"website\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"17\",{\"name\":\"twitter:title\",\"content\":\"Freak Circus Hub — Lore Archive & Theory Hub\"}],[\"$\",\"meta\",\"18\",{\"name\":\"twitter:description\",\"content\":\"Every ending mapped. Every character connected. Every theory documented.\"}],[\"$\",\"meta\"