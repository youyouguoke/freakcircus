"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Historical Record\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm whitespace-pre-line\",\"children\":\"The Null Performer first appeared in community reports in 2025, when players began noticing background figures in screenshots. Data miners later found 14 dialogue references where characters mention 'the one who watches,' 'the empty costume,' or 'the sixth chair.' The entity has never been officially acknowledged by the developers, and some believe it is a cut character whose data was partially removed but whose references remain in the dialogue files.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Evidence\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm whitespace-pre-line\",\"children\":\"1. 14 dialogue references across 4 scenes. 2. Background figures in screenshots that do not match any character sprite. 3. Audio files containing breathing sounds at 12 BPM. 4. Unused files referencing 'Director' and 'Observer' roles. 5. The Null Route's empty corridors may be the Null Performer's 'stage.'\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Related Characters\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm whitespace-pre-line\",\"children\":\"• All Characters: Reference 'the one who watches' in certain dialogue branches. • Pierrot: Describes the Null Performer as 'not one of us' in Loop 3+. • Columbina: Her three-loop storyline implies she is aware of the entity. • The Doctor: His files reference an 'Observer' who monitors the experiment.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Related Endings\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm whitespace-pre-line\",\"children\":\"• Corrupted Data: The ending's empty corridors may be the Null Performer's domain. • Null Route: The route with no characters may be the Null Performer's perspective. • Columbina's Truth: The fourth door leads to a room where 'someone is always watching.'\"}]]}],\"$L3\",\"$L4\",\"$L5\",\"$L6\"]}]]}]}],\"$L7\"]}],[\"$L8\"],\"$L9\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"IUN3TAefIj9tb0lzb6JCd\"}\n3:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Related Theories\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm whitespace-pre-line\",\"children\":\"• Observer Theory: The Null Performer is the game's director, monitoring the player's progress. • Player Theory: The entity represents the player themselves, existing in the circus without a scripted role. • Cut Character Theory: The Null Performer was a planned character whose implementation was abandoned.\"}]]}]\n4:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Community Debate\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm whitespace-pre-line\",\"children\":\"The community is divided on whether the Null Performer is real or a data artifact. The 'real' camp points to the consistent dialogue references and background sightings. The 'artifact' camp argues that the entity is a collection of unused assets that coincidentally create the illusion of a hidden character. A third faction suggests the Null Performer is an ARG element — a real-world puzzle that requires solving outside the game client.\"}]]}]\n5:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"FAQ\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm whitespace-pre-line\",\"children\":\"Q: Has anyone seen the Null Performer? A: Multiple players report background figures in screenshots, but no one has confirmed direct interaction. Q: Is the Null Performer the same as the Director? A: Possibly. The Director is referenced in unused files and ending credits, but never appears in the game. Q: Can I unlock the Null Performer as a character? A: No. Despite community attempts, no method has been found to make the entity interactable.\"}]]}]\n6:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Related Content\"}],[\"$\",\"div\",null,{\"className\":\"grid md:grid-cols-2 gap-4\",\"children\":[[\"$\",\"$La\",null,{\"href\":\"/walkthroughs/null-route\",\"className\":\"bg-surface-container border border-outline/20 p-4 hover:border-primary transition-colors\",\"children\":[[\"$\",\"div\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant mb-1\",\"children\":\"Related Route\"}],[\"$\",\"div\",null,{\"className\":\"font-bold text-foreground\",\"children\":\"Null Route →\"}],[\"$\",\"div\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The corrupted route with no characters\"}]]}],[\"$\",\"$La\",null,{\"href\":\"/theories\",\"className\":\"bg-surface-container border border-outline/20 p-4 hover:border-primary transition-colors\",\"children\":[[\"$\",\"div\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant mb-1\",\"children\":\"Related Theory\"}],[\"$\",\"div\",null,{\"className\":\"font-bold text-foreground\",\"children\":\"Observer Theory →\"}],[\"$\",\"div\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Who watches from outside the narrative\"}]]}]]}]]}]\n7:[\"$\",\"footer\",null,{\"className\":\"bg-surface border-t border-outline/10 w-full\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-6xl mx-auto px-4 md:px-16 py-6 flex flex-col md:flex-row justify-between items-center gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4\",\"children\":[[\"$\",\"img\",null,{\"src\":\"/favicon-32x32.png\",\"alt\":\"Freak Circus Hub\",\"className\":\"w-8 h-8 rounded-sm\"}],[\"$\",\"span\",null,{\"className\":\"font-[Epilogue] text-lg font-bold text-foreground\",\"children\":\"FREAK CIRCUS HUB\"}],[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant opacity-60\",\"children\":\"© 2026\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-xs text-on-surface-variant opacity-60 text-center max-w-md\",\"children\":[\"Not affiliated with the original game or its developers. All trademarks belong to their respective owners.\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:hello@freak-circus.com\",\"className\":\"underline hover:text-primary transition-colors\",\"children\":\"Contact us for removal requests\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"$La\",null,{\"href\":\"/privacy-policy\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Privacy\"}],[\"$\",\"$La\",null,{\"href\":\"/terms-of-service\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Terms\"}],[\"$\",\"a\",null,{\"href\":\"mailto:hello@freak-circus.com\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Contact\"}]]}]]}]}]\n8:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0_kxktbm0~zp0.js\",\"async\":true}]\n9:[\"$\",\"$Lb\",null,{\"children\":[\"$\",\"$c\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@d\"}]}]\nd:null\n","