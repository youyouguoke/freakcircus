,null,false,\"$@b\"]},null,false,null],\"$Lc\",false]],\"m\":\"$undefined\",\"G\":[\"$d\",[\"$Le\"]],\"S\":true,\"h\":null,\"s\":\"$undefined\",\"l\":\"$undefined\",\"p\":\"$undefined\",\"d\":\"$undefined\",\"b\":\"TLbwCga2sWMTi4GXj34iv\"}\n15:I[22016,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_kxktbm0~zp0.js\"],\"\"]\n17:I[97367,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"OutletBoundary\"]\n18:\"$Sreact.suspense\"\n1b:I[97367,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"ViewportBoundary\"]\n1d:I[97367,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"MetadataBoundary\"]\n:HL[\"/favicon-32x32.png\",\"image\"]\n5:[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-lg mb-8\",\"children\":\"Complete catalog of all Pierrot route endings, including standard, secret, and corrupted outcomes.\"}]\n6:[\"$\",\"div\",null,{\"className\":\"space-y-12\",\"children\":[[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"How Many Endings Does Pierrot Have?\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The community has confirmed three endings on Pierrot's route: one standard ending, one secret ending, and one corrupted ending found in unused game files. The standard ending unlocks through normal play, while the secret ending requires specific refusal conditions. The corrupted ending remains unverified — no player has legitimately unlocked it.\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Pierrot's endings are notable for their narrative complexity. Unlike other characters whose endings resolve their storylines, Pierrot's endings suggest that the circus itself is aware of the player and that repeated playthroughs are not separate attempts but continuations of a single narrative.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Smile For Me — Standard Ending\"}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 mb-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-primary border border-primary/30 px-2 py-1\",\"children\":\"STANDARD\"}],[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Difficulty: Normal\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The standard ending for Pierrot's route triggers when players accept his offer during the garden scene in Act III. This is the ending most players see on their first playthrough and serves as the baseline for understanding Pierrot's character arc.\"}],[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Unlock Conditions\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-on-surface-variant text-sm\",\"children\":[[\"$\",\"li\",null,{\"children\":\"• Select \\\"Accept\\\" in the garden scene (Scene 9)\"}],[\"$\",\"li\",null,{\"children\":\"• Maintain positive dialogue choices throughout Acts I and II\"}],[\"$\",\"li\",null,{\"children\":\"• Do not refuse more than two dialogue interactions in the final act\"}]]}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The ending concludes with Pierrot removing his mask, revealing a face that the player cannot clearly see. The screen fades to white as carnival music plays. Post-credits, a brief scene shows the garden empty with a single red thread on the ground.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Eternal Silence — Secret Ending\"}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 mb-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-blood border border-blood/30 px-2 py-1\",\"children\":\"SECRET\"}],[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Difficulty: Hard\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"Eternal Silence is Pierrot's secret ending and one of the most discussed outcomes in the community. It requires refusing every major dialogue interaction during the final act, turning silence into a deliberate narrative choice that breaks the game's contract with the player.\"}],[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Unlock Conditions\"}],\"$Lf\"]}],\"$L10\",\"$L11\"]}],\"$L12\",\"$L13\",\"$L14\"]}]\n7:[\"$\",\"footer\",null,{\"className\":\"bg-surface border-t border-outline/10 w-full\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-6xl mx-auto px-4 md:px-16 py-6 flex flex-col md:flex-row justify-between items-center gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4\",\"children\":[[\"$\",\"img\",null,{\"src\":\"/favicon-32x32.png\",\"alt\":\"Freak Circus Hub\",\"className\":\"w-8 h-8 rounded-sm\"}],[\"$\",\"span\",null,{\"className\":\"font-[Epilogue] text-lg font-bold text-foreground\",\"children\":\"FREAK CIRCUS HUB\"}],[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant opacity-60\",\"children\":\"© 2026\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-xs text-on-surface-variant opacity-60 text-center max-w-md\",\"children\":[\"Not affiliated with the original game or its developers. All trademarks belong to their respective owners.\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:hello@freak-circus.com\",\"className\":\"underline hover:text-primary transition-colors\",\"children\":\"Contact us for removal requests\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"$L15\",null,{\"href\":\"/privacy-policy\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Privacy\"}],[\"$\",\"$L15\",null,{\"href\":\"/terms-of-service\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Terms\"}],[\"$\",\"a\",null,{\"href\":\"mailto:hello@freak-circus.com\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Contact\"}]]}]]}]}]\n16:T1339,{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"WebPage\",\"@id\":\"https://freak-circus.com/#webpage\",\"url\":\"https://freak-circus.com\",\"name\":\"The Freak Circus Guide, Endings, Characters & Hidden Lore Archive\",\"description\":\"The ultimate fan archive for The Freak Circus horror visual novel. Explore character guides, all endings explained, walkthroughs, hidden routes, timeline lore, and community theories.\",\"isPartOf\":{\"@id\":\"https://freak-circus.com/#website\"},\"about\":{\"@type\":\"VideoGame\",\"name\":\"The Freak Circus\",\"genre\":[\"Horror\",\"Visual Novel\",\"Indie\"],\"applicationCategory\":\"Game\",\"operatingSystem\":\"Any\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}},{\"@type\":\"WebSite\",\"@id\":\"https://freak-circus.com/#website\",\"url\":\"https://freak-circus.com\",\"name\":\"Freak Circus Hub\",\"description\":\"A fan-maintained archive documenting characters, endings, theories, and hidden routes for The Freak Circus.\",\"publisher\":{\"@id\":\"https://freak-circus.com/#organization\"}},{\"@type\":\"Organization\",\"@id\":\"https://freak-circus.com/#organization\",\"name\":\"Freak Circus Hub\",\"url\":\"https://freak-circus.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://freak-circus.com/Logo.png\"}},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://freak-circus.com\"}]},{\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Freak Circus is an indie psychological horror visual novel that uses replay-aware mechanics to create a meta-narrative experience. Unlike traditional horror games, it builds dread through silence, repetition, and characters who appear to remember your choices across playthroughs.\"}},{\"@type\":\"Question\",\"name\":\"Is The Freak Circus free to play?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, The Freak Circus is available for free on itch.io. It runs directly in your browser without requiring download or installation. The game is rated 18+ for mature themes.\"}},{\"@type\":\"Question\",\"name\":\"How long is The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A single route playthrough takes approximately 4-6 hours. However, experiencing all content requires multiple playthroughs due to replay-aware mechanics, hidden triggers, and route dependencies. A comprehensive investigation to see all endings and hidden content can take 40+ hours.\"}},{\"@type\":\"Question\",\"name\":\"How many endings are in The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The exact number remains unknown. The community has confirmed 8 endings including standard routes (Grand Finale, Smile For Me, Doctor's Note), secret endings (Eternal Silence, Columbina's Truth), and corrupted endings (Corrupted Data, White Room).\"}},{\"@type\":\"Question\",\"name\":\"Who is Pierrot in The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pierrot is the melancholic clown and often the first route players encounter. His storyline explores themes of forgotten identity, repeated loops, and awareness that extends beyond the fourth wall. The loop theory suggests Pierrot remembers player behavior across save files.\"}},{\"@type\":\"Question\",\"name\":\"What is the Eternal Silence ending and how do you unlock it?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Eternal Silence is a secret ending on Pierrot's route that requires refusing every major dialogue interaction during the final act. The screen remains black for several minutes before credits roll. The ending suggests the only escape from the circus is to stop engaging entirely.\"}},{\"@type\":\"Question\",\"name\":\"What is the true ending of The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The community has not reached consensus on a true ending. Some theories suggest Columbina's Truth represents the most complete revelation. Others argue the Corrupted Data ending was intended as the true ending before being cut. The ambiguity appears intentional.\"}}]},{\"@type\":\"ItemList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Pierrot Character Guide\",\"url\":\"https://freak-circus.com/characters/pierrot\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Harlequin Character Guide\",\"url\":\"https://freak-circus.com/characters/harlequin\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"The Doctor Character Guide\",\"url\":\"https://freak-circus.com/characters/doctor\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Columbina Character Guide\",\"url\":\"https://freak-circus.com/characters/columbina\"},{\"@type\":\"ListItem\",\"position\":5,\"name\":\"All Endings Explained\",\"url\":\"https://freak-circus.com/endings\"},{\"@type\":\"ListItem\",\"position\":6,\"name\":\"Eternal Silence Ending Guide\",\"url\":\"https://freak-circus.com/endings/eternal-silence\"},{\"@type\":\"ListItem\",\"position\":7,\"name\":\"Walkthroughs\",\"url\":\"https://freak-circus.com/walkthroughs\"},{\"@type\":\"ListItem\",\"position\":8,\"name\":\"Lore Archive\",\"url\":\"https://freak-circus.com/lore\"}]}]}8:[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$16\"}}]\n9:[\"$\",\"script\",\"script-0\",{\"src\":\"/_next/static/chunks/0_kxktbm0~zp0.js\",\"async\":true,\"nonce\":\"$undefined\"}]\na:[\"$\",\"$L17\",null,{\"children\":[\"$\",\"$18\",null,{\"name\":\"Next.MetadataOutlet\",\"children\":\"$@19\"}]}]\n1a:[]\nb:\"$W1a\"\nc:[\"$\",\"$1\",\"h\",{\"children\":[null,[\"$\",\"$L1b\",null,{\"children\":\"$L1c\"}],[\"$\",\"div\",null,{\"hidden\":true,\"children\":[\"$\",\"$L1d\",null,{\"children\":[\"$\",\"$18\",null,{\"name\":\"Next.Metadata\",\"children\":\"$L1e\"}]}]}],null]}]\ne:[\"$\",\"link\",\"0\",{\"rel\":\"stylesheet\",\"href\":\"/_next/static/chunks/08m9azn6wt-jz.css\",\"precedence\":\"next\",\"crossOrigin\":\"$undefined\",\"nonce\":\"$undefined\"}]\nf:[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-on-surface-variant text-sm\",\"children\":[[\"$\",\"li\",null,{\"children\":\"• Refuse all dialogue options in Scenes 10, 11, and 12\"}],[\"$\",\"li\",null,{\"children\":\"• Do not select Comfort or Confess in the garden scene\"}],[\"$\",\"li\",null,{\"children\":\"• Ignore Pierrot's direct questions in Scene 14\"}],[\"$\",\"li\",null,{\"children\":\"• Requires cross-route awareness flag (complete one other route first)\"}]]}]\n10:[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The ending plays out over 3-4 minutes of black screen. During this time, Pierrot's voice narrates events from previous playthroughs that the player never selected. The narration includes specific choices from other routes, suggesting that Pierrot's awareness extends beyond the current save file.\"}]\n11:[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"When the credits finally roll, they are silent. No music plays. Post-credits, a 30-second scene shows Pierrot alone in the garden, speaking to an empty chair. The dialogue references the player's real-world playtime: \\\"You've been here for [X] hours. You could have left at any time.\\\"\"}]\n12:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Null Route — Corrupted Ending\"}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 mb-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant border border-outline/30 px-2 py-1\",\"children\":\"CORRUPTED\"}],[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Difficulty: Unknown\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The Null Route is a corrupted ending found in unused game files but never legitimately unlocked by any player. Data miners discovered references to this ending in build 1.04, with memory addresses that do not match any known scene IDs.\"}],[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"What We Know\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-on-surface-variant text-sm\",\"children\":[[\"$\",\"li\",null,{\"children\":\"• File name: ending_null_pierrot.dat\"}],[\"$\",\"li\",null,{\"children\":\"• Contains placeholder dialogue: \\\"No one is here. No one was ever here.\\\"\"}],[\"$\",\"li\",null,{\"children\":\"• Map file shows empty corridors with no character sprites\"}],[\"$\",\"li\",null,{\"children\":\"• Soft-locks after 5 minutes of walking\"}]]}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The community is divided on whether this is a debug remnant or an intentionally hidden ending. Some players believe it requires a specific sequence of failed routes across all characters. Others think it was cut content that remains partially accessible through file manipulation.\"}]]}]\n13:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Ending Comparison\"}],[\"$\",\"div\",null,{\"className\":\"overflow-x-auto\",\"children\":[\"$\",\"table\",null,{\"className\":\"w-full text-sm\",\"children\":[[\"$\",\"thead\",null,{\"children\":[\"$\",\"tr\",null,{\"className\":\"border-b border-outline/20\",\"children\":[[\"$\",\"th\",null,{\"className\":\"text-left p-3 text-foreground\",\"children\":\"Ending\"}],[\"$\",\"th\",null,{\"className\":\"text-left p-3 text-foreground\",\"children\":\"Type\"}],[\"$\",\"th\",null,{\"className\":\"text-left p-3 text-foreground\",\"children\":\"Difficulty\"}],[\"$\",\"th\",null,{\"className\":\"text-left p-3 text-foreground\",\"children\":\"Replay Required\"}]]}]}],[\"$\",\"tbody\",null,{\"children\":[[\"$\",\"tr\",null,{\"className\":\"border-b border-outline/10\",\"children\":[[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Smile For Me\"}],[\"$\",\"td\",null,{\"className\":\"p-3\",\"children\":[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-primary\",\"children\":\"Standard\"}]}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Normal\"}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"No\"}]]}],[\"$\",\"tr\",null,{\"className\":\"border-b border-outline/10\",\"children\":[[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Eternal Silence\"}],[\"$\",\"td\",null,{\"className\":\"p-3\",\"children\":[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-blood\",\"children\":\"Secret\"}]}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Hard\"}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Yes (1 route)\"}]]}],[\"$\",\"tr\",null,{\"children\":[[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Null Route\"}],[\"$\",\"td\",null,{\"className\":\"p-3\",\"children\":[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Corrupted\"}]}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Unknown\"}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Unverified\"}]]}]]}]]}]}]]}]\n14:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Related Content\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[\"$\",\"a\",null,{\"href\":\"/characters/pierrot\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Pierrot Route Guide\"}],[\"$\",\"a\",null,{\"href\":\"/endings/eternal-silence\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Eternal Silence Deep Dive\"}],[\"$\",\"a\",null,{\"href\":\"/theories/pierrot-remembers-routes\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Pierrot Loop Theory\"}],[\"$\",\"a\",null,{\"href\":\"/lore/mirror-hall\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Mirror Hall Lore\"}]]}]]}]\n1c:[[\"$\",\"meta\",\"0\",{\"charSet\":\"utf-8\"}],[\"$\",\"meta\",\"1\",{\"name\":\"viewport\",\"content\":\"width=device-width, initial-scale=1\"}]]\n1f:I[27201,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"IconMark\"]\n19:null\n1e:[[\"$\",\"title\",\"0\",{\"children\":\"Pierrot Endings Guide — Smile For Me, Eternal Silence & Null Route | Freak Circus Hub\"}],[\"$\",\"meta\",\"1\",{\"name\":\"description\",\"content\":\"All Pierrot endings explained: Smile For Me (main), Eternal Silence (secret), and Null Route (corrupted). Includes unlock conditions, scene requirements, and community verification status.\"}],[\"$\",\"meta\",\"2\",{\"name\":\"author\",\"content\":\"Freak Circus Hub\"}],[\"$\",\"meta\",\"3\",{\"name\":\"keywords\",\"content\":\"Pierrot endings,Eternal Silence,Smile For Me,Null Route,Pierrot route endings,The Freak Circus endings\"}],[\"$\",\"meta\",\"4\",{\"name\":\"creator\",\"content\":\"Freak Circus Hub\"}],[\"$\",\"meta\",\"5\",{\"name\":\"publisher\",\"content\":\"Freak Circus Hub\"}],[\"$\",\"meta\",\"6\",{\"name\":\"robots\",\"content\":\"index, follow\"}],[\"$\",\"meta\",\"7\",{\"name\":\"googlebot\",\"content\":\"index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1\"}],[\"$\",\"link\",\"8\",{\"rel\":\"canonical\",\"href\":\"https://freak-circus.com/characters/pierrot-endings\"}],[\"$\",\"meta\",\"9\",{\"property\":\"og:title\",\"content\":\"Pierrot Endings Guide — Smile For Me, Eternal Silence & Null Route\"}],[\"$\",\"meta\",\"10\",{\"property\":\"og:description\",\"content\":\"All Pierrot endings explained with unlock conditions and community verification.\"}],[\"$\",\"meta\",\"11\",{\"property\":\"og:url\",\"content\":\"https://freak-circus.com/characters/pierrot-endings\"}],[\"$\",\"meta\",\"12\",{\"property\":\"og:type\",\"content\":\"article\"}],[\"$\",\"meta\",\"13\",{\"name\":\"twitter:card\",\"content\":\"summary_large_image\"}],[\"$\",\"meta\",\"14\",{\"name\":\"twitter:title\",\"content\":\"Freak Circus Hub — Lore Archive & Theory Hub\"}],[\"$\",\"meta\",\"15\",{\"name\":\"twitter:description\",\"content\":\"Every ending mapped. Every character connected. Every theory documented.\"}],[\"$\",\"meta\",\"16\",{\"name\":\"twitter:image\",\"content\":\"https://freak-circus.com/twitter-image.png\"}],[\"$\",\"link\",\"17\",{\"rel\":\"icon\",\"href\":\"/favicon.ico?favicon.0x3dzn~oxb6tn.ico\",\"sizes\":\"256x256\",\"type\":\"image/x-icon\"}],[\"$\",\"link\",\"18\",{\"rel\":\"icon\",\"href\":\"/Logo.png\"}],[\"$\",\"link\",\"19\",{\"rel\":\"apple-touch-icon\",\"href\":\"/Logo.png\"}],[\"$\",\"$L1f\",\"20\",{}]]\n","/characters/pierrot-endings/__PAGE__":"1:\"$Sreact.fragment\"\n2:I[88589,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_kxktbm0~zp0.js\"],\"default\"]\n10:I[22016,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_kxktbm0~zp0.js\"],\"\"]\n12:I[97367,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"OutletBoundary\"]\n13:\"$Sreact.suspense\"\n:HL[\"/favicon-32x32.png\",\"image\"]\n0:{\"rsc\":[\"$\",\"$1\",\"c\",{\"children\":[[\"$\",\"main\",null,{\"className\":\"min-h-screen\",\"children\":[[\"$\",\"$L2\",null,{}],[\"$\",\"article\",null,{\"className\":\"bg-surface py-16 px-4 md:px-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-4xl mx-auto\",\"children\":[[\"$\",\"div\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant mb-4\",\"children\":\"ENDING_GUIDE // PIERROT\"}],[\"$\",\"h1\",null,{\"className\":\"font-[Creepster] text-4xl md:text-6xl text-primary mb-4\",\"children\":\"Pierrot Endings Guide\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-lg mb-8\",\"children\":\"Complete catalog of all Pierrot route endings, including standard, secret, and corrupted outcomes.\"}],[\"$\",\"div\",null,{\"className\":\"space-y-12\",\"children\":[[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"How Many Endings Does Pierrot Have?\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The community has confirmed three endings on Pierrot's route: one standard ending, one secret ending, and one corrupted ending found in unused game files. The standard ending unlocks through normal play, while the secret ending requires specific refusal conditions. The corrupted ending remains unverified — no player has legitimately unlocked it.\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Pierrot's endings are notable for their narrative complexity. Unlike other characters whose endings resolve their storylines, Pierrot's endings suggest that the circus itself is aware of the player and that repeated playthroughs are not separate attempts but continuations of a single narrative.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Smile For Me — Standard Ending\"}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 mb-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-primary border border-primary/30 px-2 py-1\",\"children\":\"STANDARD\"}],[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Difficulty: Normal\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The standard ending for Pierrot's route triggers when players accept his offer during the garden scene in Act III. This is the ending most players see on their first playthrough and serves as the baseline for understanding Pierrot's character arc.\"}],[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Unlock Conditions\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-on-surface-variant text-sm\",\"children\":[[\"$\",\"li\",null,{\"children\":\"• Select \\\"Accept\\\" in the garden scene (Scene 9)\"}],[\"$\",\"li\",null,{\"children\":\"• Maintain positive dialogue choices throughout Acts I and II\"}],[\"$\",\"li\",null,{\"children\":\"• Do not refuse more than two dialogue interactions in the final act\"}]]}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The ending concludes with Pierrot removing his mask, revealing a face that the player cannot clearly see. The screen fades to white as carnival music plays. Post-credits, a brief scene shows the garden empty with a single red thread on the ground.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Eternal Silence — Secret Ending\"}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 mb-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-blood border border-blood/30 px-2 py-1\",\"children\":\"SECRET\"}],\"$L3\"]}],\"$L4\",\"$L5\",\"$L6\"]}],\"$L7\",\"$L8\"]}],\"$L9\",\"$La\",\"$Lb\"]}]]}]}],\"$Lc\",\"$Ld\"]}],[\"$Le\"],\"$Lf\"]}],\"isPartial\":false,\"staleTime\":300,\"varyParams\":null,\"buildId\":\"TLbwCga2sWMTi4GXj34iv\"}\n3:[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Difficulty: Hard\"}]\n4:[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"Eternal Silence is Pierrot's secret ending and one of the most discussed outcomes in the community. It requires refusing every major dialogue interaction during the final act, turning silence into a deliberate narrative choice that breaks the game's contract with the player.\"}]\n5:[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"Unlock Conditions\"}]\n6:[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-on-surface-variant text-sm\",\"children\":[[\"$\",\"li\",null,{\"children\":\"• Refuse all dialogue options in Scenes 10, 11, and 12\"}],[\"$\",\"li\",null,{\"children\":\"• Do not select Comfort or Confess in the garden scene\"}],[\"$\",\"li\",null,{\"children\":\"• Ignore Pierrot's direct questions in Scene 14\"}],[\"$\",\"li\",null,{\"children\":\"• Requires cross-route awareness flag (complete one other route first)\"}]]}]\n7:[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The ending plays out over 3-4 minutes of black screen. During this time, Pierrot's voice narrates events from previous playthroughs that the player never selected. The narration includes specific choices from other routes, suggesting that Pierrot's awareness extends beyond the current save file.\"}]\n8:[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"When the credits finally roll, they are silent. No music plays. Post-credits, a 30-second scene shows Pierrot alone in the garden, speaking to an empty chair. The dialogue references the player's real-world playtime: \\\"You've been here for [X] hours. You could have left at any time.\\\"\"}]\n9:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Null Route — Corrupted Ending\"}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6 mb-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-3 mb-4\",\"children\":[[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant border border-outline/30 px-2 py-1\",\"children\":\"CORRUPTED\"}],[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Difficulty: Unknown\"}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The Null Route is a corrupted ending found in unused game files but never legitimately unlocked by any player. Data miners discovered references to this ending in build 1.04, with memory addresses that do not match any known scene IDs.\"}],[\"$\",\"h3\",null,{\"className\":\"font-bold text-foreground mb-2\",\"children\":\"What We Know\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-on-surface-variant text-sm\",\"children\":[[\"$\",\"li\",null,{\"children\":\"• File name: ending_null_pierrot.dat\"}],[\"$\",\"li\",null,{\"children\":\"• Contains placeholder dialogue: \\\"No one is here. No one was ever here.\\\"\"}],[\"$\",\"li\",null,{\"children\":\"• Map file shows empty corridors with no character sprites\"}],[\"$\",\"li\",null,{\"children\":\"• Soft-locks after 5 minutes of walking\"}]]}]]}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The community is divided on whether this is a debug remnant or an intentionally hidden ending. Some players believe it requires a specific sequence of failed routes across all characters. Others think it was cut content that remains partially accessible through file manipulation.\"}]]}]\na:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Ending Comparison\"}],[\"$\",\"div\",null,{\"className\":\"overflow-x-auto\",\"children\":[\"$\",\"table\",null,{\"className\":\"w-full text-sm\",\"children\":[[\"$\",\"thead\",null,{\"children\":[\"$\",\"tr\",null,{\"className\":\"border-b border-outline/20\",\"children\":[[\"$\",\"th\",null,{\"className\":\"text-left p-3 text-foreground\",\"children\":\"Ending\"}],[\"$\",\"th\",null,{\"className\":\"text-left p-3 text-foreground\",\"children\":\"Type\"}],[\"$\",\"th\",null,{\"className\":\"text-left p-3 text-foreground\",\"children\":\"Difficulty\"}],[\"$\",\"th\",null,{\"className\":\"text-left p-3 text-foreground\",\"children\":\"Replay Required\"}]]}]}],[\"$\",\"tbody\",null,{\"children\":[[\"$\",\"tr\",null,{\"className\":\"border-b border-outline/10\",\"children\":[[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Smile For Me\"}],[\"$\",\"td\",null,{\"className\":\"p-3\",\"children\":[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-primary\",\"children\":\"Standard\"}]}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Normal\"}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"No\"}]]}],[\"$\",\"tr\",null,{\"className\":\"border-b border-outline/10\",\"children\":[[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Eternal Silence\"}],[\"$\",\"td\",null,{\"className\":\"p-3\",\"children\":[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-blood\",\"children\":\"Secret\"}]}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Hard\"}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Yes (1 route)\"}]]}],[\"$\",\"tr\",null,{\"children\":[[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Null Route\"}],[\"$\",\"td\",null,{\"className\":\"p-3\",\"children\":[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Corrupted\"}]}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Unknown\"}],[\"$\",\"td\",null,{\"className\":\"p-3 text-on-surface-variant\",\"children\":\"Unverified\"}]]}]]}]]}]}]]}]\nb:[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Related Content\"}],[\"$\",\"div\",null,{\"className\":\"flex flex-wrap gap-2\",\"children\":[[\"$\",\"a\",null,{\"href\":\"/characters/pierrot\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Pierrot Route Guide\"}],[\"$\",\"a\",null,{\"href\":\"/endings/eternal-silence\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Eternal Silence Deep Dive\"}],[\"$\",\"a\",null,{\"href\":\"/theories/pierrot-remembers-routes\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Pierrot Loop Theory\"}],[\"$\",\"a\",null,{\"href\":\"/lore/mirror-hall\",\"className\":\"font-[JetBrains_Mono] text-xs px-3 py-1 border border-outline/30 text-on-surface-variant hover:border-primary hover:text-primary transition-colors\",\"children\":\"Mirror Hall Lore\"}]]}]]}]\nc:[\"$\",\"footer\",null,{\"className\":\"bg-surface border-t border-outline/10 w-full\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-6xl mx-auto px-4 md:px-16 py-6 flex flex-col md:flex-row justify-between items-center gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4\",\"children\":[[\"$\",\"img\",null,{\"src\":\"/favicon-32x32.png\",\"alt\":\"Freak Circus Hub\",\"className\":\"w-8 h-8 rounded-sm\"}],[\"$\",\"span\",null,{\"className\":\"font-[Epilogue] text-lg font-bold text-foreground\",\"children\":\"FREAK CIRCUS HUB\"}],[\"$\",\"span\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant opacity-60\",\"children\":\"© 2026\"}]]}],[\"$\",\"div\",null,{\"className\":\"text-xs text-on-surface-variant opacity-60 text-center max-w-md\",\"children\":[\"Not affiliated with the original game or its developers. All trademarks belong to their respective owners.\",\" \",[\"$\",\"a\",null,{\"href\":\"mailto:hello@freak-circus.com\",\"className\":\"underline hover:text-primary transition-colors\",\"children\":\"Contact us for removal requests\"}]]}],[\"$\",\"div\",null,{\"className\":\"flex gap-4\",\"children\":[[\"$\",\"$L10\",null,{\"href\":\"/privacy-policy\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Privacy\"}],[\"$\",\"$L10\",null,{\"href\":\"/terms-of-service\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Terms\"}],[\"$\",\"a\",null,{\"href\":\"mailto:hello@freak-circus.com\",\"className\":\"font-[JetBrains_Mono] text-xs uppercase text-on-surface-variant opacity-60 hover:text-primary transition-colors\",\"children\":\"Contact\"}]]}]]}]}]\n11:T1339,{\"@context\":\"https://schema.org\",\"@graph\":[{\"@type\":\"WebPage\",\"@id\":\"https://freak-circus.com/#webpage\",\"url\":\"https://freak-circus.com\",\"name\":\"The Freak Circus Guide, Endings, Characters & Hidden Lore Archive\",\"description\":\"The ultimate fan archive for The Freak Circus horror visual novel. Explore character guides, all endings explained, walkthroughs, hidden routes, timeline lore, and community theories.\",\"isPartOf\":{\"@id\":\"https://freak-circus.com/#website\"},\"about\":{\"@type\":\"VideoGame\",\"name\":\"The Freak Circus\",\"genre\":[\"Horror\",\"Visual Novel\",\"Indie\"],\"applicationCategory\":\"Game\",\"operatingSystem\":\"Any\",\"offers\":{\"@type\":\"Offer\",\"price\":\"0\",\"priceCurrency\":\"USD\"}}},{\"@type\":\"WebSite\",\"@id\":\"https://freak-circus.com/#website\",\"url\":\"https://freak-circus.com\",\"name\":\"Freak Circus Hub\",\"description\":\"A fan-maintained archive documenting characters, endings, theories, and hidden routes for The Freak Circus.\",\"publisher\":{\"@id\":\"https://freak-circus.com/#organization\"}},{\"@type\":\"Organization\",\"@id\":\"https://freak-circus.com/#organization\",\"name\":\"Freak Circus Hub\",\"url\":\"https://freak-circus.com\",\"logo\":{\"@type\":\"ImageObject\",\"url\":\"https://freak-circus.com/Logo.png\"}},{\"@type\":\"BreadcrumbList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Home\",\"item\":\"https://freak-circus.com\"}]},{\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The Freak Circus is an indie psychological horror visual novel that uses replay-aware mechanics to create a meta-narrative experience. Unlike traditional horror games, it builds dread through silence, repetition, and characters who appear to remember your choices across playthroughs.\"}},{\"@type\":\"Question\",\"name\":\"Is The Freak Circus free to play?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes, The Freak Circus is available for free on itch.io. It runs directly in your browser without requiring download or installation. The game is rated 18+ for mature themes.\"}},{\"@type\":\"Question\",\"name\":\"How long is The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"A single route playthrough takes approximately 4-6 hours. However, experiencing all content requires multiple playthroughs due to replay-aware mechanics, hidden triggers, and route dependencies. A comprehensive investigation to see all endings and hidden content can take 40+ hours.\"}},{\"@type\":\"Question\",\"name\":\"How many endings are in The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The exact number remains unknown. The community has confirmed 8 endings including standard routes (Grand Finale, Smile For Me, Doctor's Note), secret endings (Eternal Silence, Columbina's Truth), and corrupted endings (Corrupted Data, White Room).\"}},{\"@type\":\"Question\",\"name\":\"Who is Pierrot in The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Pierrot is the melancholic clown and often the first route players encounter. His storyline explores themes of forgotten identity, repeated loops, and awareness that extends beyond the fourth wall. The loop theory suggests Pierrot remembers player behavior across save files.\"}},{\"@type\":\"Question\",\"name\":\"What is the Eternal Silence ending and how do you unlock it?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Eternal Silence is a secret ending on Pierrot's route that requires refusing every major dialogue interaction during the final act. The screen remains black for several minutes before credits roll. The ending suggests the only escape from the circus is to stop engaging entirely.\"}},{\"@type\":\"Question\",\"name\":\"What is the true ending of The Freak Circus?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"The community has not reached consensus on a true ending. Some theories suggest Columbina's Truth represents the most complete revelation. Others argue the Corrupted Data ending was intended as the true ending before being cut. The ambiguity appears intentional.\"}}]},{\"@type\":\"ItemList\",\"itemListElement\":[{\"@type\":\"ListItem\",\"position\":1,\"name\":\"Pierrot Character Guide\",\"url\":\"https://freak-circus.com/characters/pierrot\"},{\"@type\":\"ListItem\",\"position\":2,\"name\":\"Harlequin Character Guide\",\"url\":\"https://freak-circus.com/characters/harlequin\"},{\"@type\":\"ListItem\",\"position\":3,\"name\":\"The Doctor Character Guide\",\"url\":\"https://freak-circus.com/characters/doctor\"},{\"@type\":\"ListItem\",\"position\":4,\"name\":\"Columbina Character Guide\",\"url\":\"https://freak-circus.com/characters/columbina\"},{\"@type\":\"ListItem\",\"position\":5,\"name\":\"All Endings Explained\",\"url\":\"https://freak-circus.com/endings\"},{\"@type\":\"ListItem\",\