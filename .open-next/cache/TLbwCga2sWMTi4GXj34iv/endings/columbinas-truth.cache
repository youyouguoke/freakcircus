\":\"py-16 px-4 md:px-16\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-4xl mx-auto\",\"children\":[[\"$\",\"div\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant mb-4\",\"children\":\"ENDING_GUIDE // COLUMBINAS_TRUTH\"}],[\"$\",\"h1\",null,{\"className\":\"font-[Creepster] text-4xl md:text-6xl text-primary mb-4\",\"children\":\"Columbina's Truth\"}],\"$L5\",\"$L6\"]}]}],\"$L7\"]}],[\"$L8\"],\"$L9\"]}],{},null,false,null]},null,false,\"$@a\"]},null,false,\"$@a\"]},null,false,null],\"$Lb\",false]],\"m\":\"$undefined\",\"G\":[\"$c\",[\"$Ld\"]],\"S\":true,\"h\":null,\"s\":\"$undefined\",\"l\":\"$undefined\",\"p\":\"$undefined\",\"d\":\"$undefined\",\"b\":\"TLbwCga2sWMTi4GXj34iv\"}\n10:I[22016,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\",\"/_next/static/chunks/0_kxktbm0~zp0.js\"],\"\"]\n11:I[97367,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"OutletBoundary\"]\n12:\"$Sreact.suspense\"\n15:I[97367,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"ViewportBoundary\"]\n17:I[97367,[\"/_next/static/chunks/01xlw8hd842-c.js\",\"/_next/static/chunks/0d3shmwh5_nmn.js\"],\"MetadataBoundary\"]\n:HL[\"/favicon-32x32.png\",\"image\"]\n5:[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-lg mb-8\",\"children\":\"The secret ending for Columbina's route — requires perfect alignment across three consecutive loops.\"}]\n6:[\"$\",\"div\",null,{\"className\":\"space-y-12\",\"children\":[[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Overview\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Columbina's Truth is the most difficult ending to unlock in The Freak Circus. It requires perfect alignment of all dialogue choices across three consecutive loops — any deviation, even a single incorrect choice, causes a complete reset. The ending reveals that Columbina is the only character who truly understands the circus, and that her gentle demeanor hides a disturbing awareness of the narrative loop.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Requirements\"}],[\"$\",\"ul\",null,{\"className\":\"space-y-2 text-on-surface-variant text-sm\",\"children\":[[\"$\",\"li\",null,{\"children\":\"• Complete Columbina's route with perfect dialogue choices in Loop 1\"}],[\"$\",\"li\",null,{\"children\":\"• Complete Loop 2 with identical choices — any deviation resets to Loop 1\"}],[\"$\",\"li\",null,{\"children\":\"• Complete Loop 3 with identical choices — the hallway gains a fourth door\"}],[\"$\",\"li\",null,{\"children\":\"• Enter the fourth door in Scene 14 to trigger the ending\"}],[\"$\",\"li\",null,{\"children\":\"• Requires completing Pierrot's route first for cross-route awareness\"}]]}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Walkthrough\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm mb-4\",\"children\":\"The three-loop mechanic is the most demanding system in The Freak Circus. Players must remember every choice from Loop 1 and replicate them exactly in Loops 2 and 3. The game provides no indication of which choices were \\\"correct\\\" — you must deduce the pattern from Columbina's reactions.\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"In Loop 3, the hallway gains a fourth door that was not present in the initial architecture. This door leads to a room containing a single chair facing a mirror. The mirror shows the player's desktop, breaking the fourth wall explicitly.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Lore Meaning\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Columbina's Truth suggests that the circus is a purgatorial system where characters forget but the world remembers. The three loops represent stages of memory erosion — each loop strips away more of the protagonist's identity until only instinct remains. The fourth door represents the boundary between the player and the protagonist, suggesting that the player is the true variable being tested.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"Community Theory\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The community theory suggests that Columbina is not a character but a system administrator — the only entity in the circus that understands its true purpose. Her three-loop storyline is not a narrative but a calibration process, testing whether the player can maintain consistency across iterations. The ending implies that the circus exists to test human memory and decision-making under repetition.\"}]]}],[\"$\",\"section\",null,{\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\",\"children\":\"FAQ\"}],[\"$\",\"div\",null,{\"className\":\"space-y-4\",\"children\":[\"$Le\",\"$Lf\"]}]]}]]}]\n7:[\"$\",\"footer\",null,{\"className\":\"bg-surface border-t border-outline/10 w-full\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-6xl mx-auto px-4 md:px-16 py-6 flex flex-col md:flex-row justify-between items-center gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex items-center gap-4\",\"children\":[[\"$\",\"img\",null,{\"src\":\"/favicon-32x32.png\",\"alt\":\"Freak Circus Hub\",\"className\":\"w-8 h-8 rounded-sm\"}],[\"$\",\"span\",null,{\"className\":\"font-[Epilogue] text-lg font-bold text-foreground