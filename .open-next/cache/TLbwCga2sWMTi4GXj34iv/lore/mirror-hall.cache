.\\\"}]\\nf:[\\\"$\\\",\\\"section\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\\\",\\\"children\\\":\\\"FAQ\\\"}],[\\\"$\\\",\\\"p\\\",null,{\\\"className\\\":\\\"text-on-surface-variant text-sm whitespace-pre-line\\\",\\\"children\\\":\\\"Q: How do I find the Mirror Hall? A: Fail at least one route, then replay any character's route. The Hall appears as a new option in Scene 7. Q: What do the mirrors show? A: Each mirror shows events from a different route. The central mirror shows your desktop. Q: Is the Hall related to the Null Performer? A: Some players report seeing a sixth figure in the mirrors. This may be the Null Performer or the player's own reflection.\\\"}]]}]\\n10:[\\\"$\\\",\\\"section\\\",null,{\\\"children\\\":[[\\\"$\\\",\\\"h2\\\",null,{\\\"className\\\":\\\"font-[Epilogue] text-2xl font-bold text-foreground mb-4\\\",\\\"children\\\":\\\"Related Content\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"grid md:grid-cols-2 gap-4\\\",\\\"children\\\":[[\\\"$\\\",\\\"$L11\\\",null,{\\\"href\\\":\\\"/walkthroughs/pierrot-silent-route\\\",\\\"className\\\":\\\"bg-surface-container border border-outline/20 p-4 hover:border-primary transition-colors\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"font-[JetBrains_Mono] text-xs text-on-surface-variant mb-1\\\",\\\"children\\\":\\\"Related Route\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"font-bold text-foreground\\\",\\\"children\\\":\\\"Pierrot Silent Route →\\\"}],[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"text-on-surface-variant text-sm\\\",\\\"children\\\":\\\"Route where mirrors first appear\\\"}]]}],[\\\"$\\\",\\\"$L11\\\",null,{\\\"href\\\":\\\"/endings/eternal-silence\\\",\\\"className\\\":\\\"bg-surface-container border border-outline/20 p-4 hover:border-primary transition-colors\\\",\\\"children\\\":[[\\\"$\\\",\\\"div\\\",null,{\\\"className\\\":\\\"font-[