\",\"children\":\"Price\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4 text-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"font-[Creepster] text-2xl text-primary\",\"children\":\"4-6h\"}],[\"$\",\"div\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Demo Length\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4 text-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"font-[Creepster] text-2xl text-primary\",\"children\":\"Browser\"}],[\"$\",\"div\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Platform\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-4 text-center\",\"children\":[[\"$\",\"div\",null,{\"className\":\"font-[Creepster] text-2xl text-primary\",\"children\":\"18+\"}],[\"$\",\"div\",null,{\"className\":\"font-[JetBrains_Mono] text-xs text-on-surface-variant\",\"children\":\"Rating\"}]]}]]}]]}]}]\n7:[\"$\",\"section\",null,{\"className\":\"bg-surface py-16 px-4 md:px-16 border-t border-outline/10\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-4xl mx-auto\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl md:text-3xl font-bold text-primary mb-6\",\"children\":\"How to Play\"}],[\"$\",\"div\",null,{\"className\":\"space-y-6\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-[Epilogue] text-lg font-bold text-foreground mb-2\",\"children\":\"1. Choose Your Route\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"Start with Pierrot's route — it is the most accessible for new players and introduces core mechanics including the dialogue choice system and the comfort/confess dynamic. The demo also includes partial access to Harlequin's route.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-[Epilogue] text-lg font-bold text-foreground mb-2\",\"children\":\"2. Make Dialogue Choices\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The game presents dialogue choices that affect character relationships and route outcomes. Some choices only appear after multiple playthroughs. The hidden counter at save file offset 0x4A20 tracks your progress across sessions.\"}]]}],[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-[Epilogue] text-lg font-bold text-foreground mb-2\",\"children\":\"3. Discover Hidden Content\"}],[\"$\",\"p\",null,{\"className\":\"text-on-surface-variant text-sm\",\"children\":\"The Freak Circus rewards repeated playthroughs. Characters reference previous choices, new dialogue options appear, and hidden scenes unlock based on your play history. The demo contains multiple endings that carry over to the full version.\"}]]}]]}]]}]}]\n8:[\"$\",\"section\",null,{\"className\":\"bg-surface py-16 px-4 md:px-16 border-t border-outline/10\",\"children\":[\"$\",\"div\",null,{\"className\":\"max-w-4xl mx-auto\",\"children\":[[\"$\",\"h2\",null,{\"className\":\"font-[Epilogue] text-2xl md:text-3xl font-bold text-primary mb-6\",\"children\":\"Controls\"}],[\"$\",\"div\",null,{\"className\":\"grid md:grid-cols-2 gap-4\",\"children\":[[\"$\",\"div\",null,{\"className\":\"bg-surface-container border border-outline/20 p-6\",\"children\":[[\"$\",\"h3\",null,{\"className\":\"font-[Epilogue] text-lg font-bold text-foreground mb-3\",\"children\":\"Keyboard\"}],[\"$\",\"div\",null,{\"className\":\"space-y-2 text-sm text-on-surface-variant\",\"children\":[[\"$\",\"div\",null,{\"className\":\"flex justify-between\",\"children\":[[\"$\",\"span\",null,{\"children\":\"Advance text\"}],[\"$\